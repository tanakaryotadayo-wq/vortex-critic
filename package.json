{
  "name": "vortex-critic",
  "displayName": "VORTEX Critic",
  "description": "DeepSeek-powered Evidence Verification & Audit Pipeline — VORTEX Protocol for AI Output Integrity",
  "version": "1.0.0",
  "publisher": "ryota-core",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vortex-sidebar",
          "title": "VORTEX",
          "icon": "media/vortex-icon.svg"
        }
      ]
    },
    "views": {
      "vortex-sidebar": [
        {
          "type": "webview",
          "id": "vortex-sidebar-webview",
          "name": "⚡ Control Center"
        }
      ]
    },
    "commands": [
      {
        "command": "vortex.openAsyncTaskDashboard",
        "title": "VORTEX: Async Task Dashboard を開く",
        "icon": "$(sparkle)"
      },
      {
        "command": "vortex.runAudit",
        "title": "VORTEX: アクティブファイルを監査",
        "icon": "$(shield)"
      },
      {
        "command": "vortex.runAuditSelection",
        "title": "VORTEX: 選択コードを監査"
      },
      {
        "command": "vortex.viewLogs",
        "title": "VORTEX: フリートログを表示"
      },
      {
        "command": "vortex.clearLogs",
        "title": "VORTEX: 今日のログを消去"
      },
      {
        "command": "vortex.refreshSidebar",
        "title": "VORTEX: サイドバーを更新",
        "icon": "$(refresh)"
      },
      {
        "command": "vortex.openNewgateSnapshot",
        "title": "VORTEX: Newgate Snapshot を開く",
        "icon": "$(light-bulb)"
      },
      {
        "command": "vortex.startGeminiBridge",
        "title": "VORTEX: Gemini Code Assist Bridge を起動",
        "icon": "$(rocket)"
      },
      {
        "command": "vortex.openGeminiBridgeSnapshot",
        "title": "VORTEX: Gemini Bridge Snapshot を開く",
        "icon": "$(radio-tower)"
      },
      {
        "command": "vortex.runPipelineOne",
        "title": "VORTEX: Pipeline① を起動",
        "icon": "$(play)"
      },
      {
        "command": "vortex.openPipelineOneSnapshot",
        "title": "VORTEX: Pipeline① Snapshot を開く",
        "icon": "$(json)"
      },
      {
        "command": "vortex.packetizeAntigravity",
        "title": "VORTEX: Antigravity を Packet 抽出",
        "icon": "$(package)"
      },
      {
        "command": "vortex.openKiQueueSnapshot",
        "title": "VORTEX: KI Queue Snapshot を開く",
        "icon": "$(book)"
      },
      {
        "command": "vortex.openKiColabNotebook",
        "title": "VORTEX: KI Colab Notebook を開く",
        "icon": "$(notebook)"
      },
      {
        "command": "vortex.promoteKiCandidate",
        "title": "VORTEX: KI 候補を昇格",
        "icon": "$(arrow-up)"
      },
      {
        "command": "vortex.switchPreset",
        "title": "VORTEX: PCC Preset を切替"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vortex.runAuditSelection",
          "group": "vortex",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "vortex.openAsyncTaskDashboard",
          "when": "view == vortex-sidebar-webview",
          "group": "navigation@1"
        },
        {
          "command": "vortex.refreshSidebar",
          "when": "view == vortex-sidebar-webview",
          "group": "navigation@2"
        },
        {
          "command": "vortex.runAudit",
          "when": "view == vortex-sidebar-webview",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "VORTEX Critic",
      "properties": {
        "vortex.preset": {
          "type": "string",
          "default": "渦",
          "enum": [
            "渦",
            "監",
            "刃",
            "探",
            "極",
            "均"
          ],
          "description": "DeepSeek critic に使う PCC Preset"
        },
        "vortex.criticScript": {
          "type": "string",
          "default": "",
          "description": "vortex-critic.py のパス（空なら自動検出）"
        },
        "vortex.autoAuditOnSave": {
          "type": "boolean",
          "default": false,
          "description": "ファイル保存時に VORTEX 監査を自動実行"
        },
        "vortex.kiQueueFile": {
          "type": "string",
          "default": "",
          "description": "KI 昇格キュー JSONL のパス（空なら自動検出）"
        },
        "vortex.kiKnowledgeDir": {
          "type": "string",
          "default": "",
          "description": "~/.gemini/antigravity/knowledge のパス（空なら自動検出）"
        },
        "vortex.kiColabNotebook": {
          "type": "string",
          "default": "",
          "description": "KI ベクトル化に使う Colab/Jupyter notebook のパス（空なら自動検出）"
        },
        "vortex.antigravityAppPath": {
          "type": "string",
          "default": "",
          "description": "Packet 抽出対象の Antigravity.app パス（空なら /Applications/Antigravity.app）"
        },
        "vortex.antigravityPacketScript": {
          "type": "string",
          "default": "",
          "description": "Antigravity packet 抽出スクリプトのパス（空なら ~/Newgate/intelligence/harvest_antigravity_packets.py）"
        },
        "vortex.antigravityPacketDbPath": {
          "type": "string",
          "default": "",
          "description": "Packet を書き込む neural_packets.db のパス（空なら ~/Newgate/intelligence/neural_packets.db）"
        },
        "vortex.antigravityPacketSummaryPath": {
          "type": "string",
          "default": "",
          "description": "Antigravity packet 抽出サマリー JSON の保存先（空なら ~/.gemini/antigravity/antigravity_packet_snapshot.json）"
        },
        "vortex.pipelineOneRepoPath": {
          "type": "string",
          "default": "",
          "description": "Pipeline① で packet 化する OSS repo のパス（空なら ~/vscode-oss）"
        },
        "vortex.pipelineOneStatusPath": {
          "type": "string",
          "default": "",
          "description": "Pipeline① status JSON のパス（空なら workspace/.build/ryota/pipeline_01/status.json）"
        },
        "vortex.pipelineOneBootstrapScript": {
          "type": "string",
          "default": "",
          "description": "Pipeline① bootstrap script のパス（空なら bundled asset を使用）"
        },
        "vortex.pipelineOneRunnerScript": {
          "type": "string",
          "default": "",
          "description": "Pipeline① runner script のパス（空なら bundled asset を使用）"
        },
        "vortex.geminiBridgeBootstrapScript": {
          "type": "string",
          "default": "",
          "description": "Gemini Code Assist bridge bootstrap script のパス（空なら bundled asset を使用）"
        },
        "vortex.geminiBridgeStatusPath": {
          "type": "string",
          "default": "",
          "description": "Gemini Code Assist bridge status JSON のパス（空なら workspace/.build/ryota/gemini-code-assist/status.json）"
        },
        "vortex.geminiBridgePort": {
          "type": "number",
          "default": 8765,
          "description": "Gemini Code Assist bridge の待受ポート"
        },

        "vortex.fusionGateUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9800",
          "description": "Fusion Gate の URL"
        },
        "vortex.fleet.utilityEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:8101",
          "description": "Utility レーン（Qwen 3.5 9B）の URL"
        },
        "vortex.fleet.agentEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:8102",
          "description": "Agent レーン（Qwen3 Coder 80B）の URL"
        },
        "vortex.fleet.conversationEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:8103",
          "description": "Conversation レーン（Gemma 4 26B）の URL"
        },
        "vortex.fleet.embeddingEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:8093/v1/embeddings",
          "description": "Embedding エンドポイント（NV-Embed-v2 4096d）の URL"
        },
        "vortex.fleet.embeddingModel": {
          "type": "string",
          "default": "nv-embed-v2",
          "description": "Embedding モデル名"
        },
        "vortex.fleet.healthCheckInterval": {
          "type": "number",
          "default": 30000,
          "description": "フリート死活チェック間隔（ms）。0で無効",
          "minimum": 0
        },

        "vortex.memory.recallOnActivate": {
          "type": "boolean",
          "default": true,
          "description": "拡張アクティベーション時に Sovereign Memory から自動 recall を実行"
        },
        "vortex.memory.autoIndexOnPromote": {
          "type": "boolean",
          "default": true,
          "description": "KI 昇格時に自動でベクトルインデックスを更新"
        },
        "vortex.memory.brainDir": {
          "type": "string",
          "default": "",
          "description": "Sovereign Memory brain ディレクトリ（空なら ~/.gemini/antigravity/brain）"
        },

        "vortex.harvest.enable": {
          "type": "boolean",
          "default": false,
          "description": "LSP パケットから AST/シンボル情報を自動収集"
        },
        "vortex.harvest.semanticDiff": {
          "type": "boolean",
          "default": false,
          "description": "ファイル変更時にセマンティック差分を計算"
        },
        "vortex.harvest.packetDbPath": {
          "type": "string",
          "default": "",
          "description": "Harvest で書き込む neural_packets.db のパス（空なら ~/Newgate/intelligence/neural_packets.db）"
        },
        "vortex.harvest.targetLanguages": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["typescript", "python", "javascript"],
          "description": "Harvest 対象の言語ID"
        },

        "vortex.stateStream.enable": {
          "type": "boolean",
          "default": false,
          "description": "エディタ状態をバックエンドへストリーミング"
        },
        "vortex.stateStream.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:9800/v1/ide/state",
          "description": "State payload の送信先エンドポイント"
        },
        "vortex.stateStream.interval": {
          "type": "number",
          "default": 5000,
          "description": "State 送信間隔（ms）",
          "minimum": 1000
        },
        "vortex.stateStream.includeDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "State に LSP diagnostics を含める"
        },
        "vortex.stateStream.includeGit": {
          "type": "boolean",
          "default": true,
          "description": "State に Git 状態（branch / changes）を含める"
        },

        "vortex.actionServer.enable": {
          "type": "boolean",
          "default": false,
          "description": "AI からのアクション命令（ファイル編集、diff 適用等）を受け付ける"
        },
        "vortex.actionServer.port": {
          "type": "number",
          "default": 19800,
          "description": "Action Server のリッスンポート"
        },
        "vortex.actionServer.allowedActions": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["openFile", "insertText", "applyDiff", "runCommand"],
          "description": "許可するアクション種別（セキュリティフィルター）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.3"
  }
}
